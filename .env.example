# ============================================================
# Neon PostgreSQL
# neon.tech でプロジェクト作成 → Connection Details から取得
# DATABASE_URL: Pooled connection（アプリ用）
# DIRECT_URL:   Direct connection（migrate用）
# ============================================================
DATABASE_URL="postgresql://user:password@ep-xxx.ap-southeast-1.aws.neon.tech/gyosei-lp?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://user:password@ep-xxx.ap-southeast-1.aws.neon.tech/gyosei-lp?sslmode=require"

# ============================================================
# Claude API（https://console.anthropic.com）
# ============================================================
ANTHROPIC_API_KEY="sk-ant-api03-..."

# ============================================================
# NextAuth（管理画面認証）
# AUTH_SECRET: openssl rand -base64 32 で生成
# ADMIN_EMAIL / ADMIN_PASSWORD: 管理画面ログイン用（自分だけ）
# ============================================================
AUTH_SECRET=""
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD=""

# ============================================================
# Resend（メール送信 https://resend.com）
# ============================================================
RESEND_API_KEY="re_..."
RESEND_FROM="noreply@yourdomain.com"

# ============================================================
# Stripe（決済 https://dashboard.stripe.com）
# STRIPE_SECRET_KEY:     APIキー → 開発者 → APIキー
# STRIPE_PRICE_MONTHLY:  月額プランの価格ID → 商品カタログ → 価格ID
# STRIPE_PRICE_ANNUAL:   年額プランの価格ID → 商品カタログ → 価格ID
# STRIPE_PRICE_COINS:    コインパック（20回/¥300）の価格ID → 商品カタログ → 価格ID
# STRIPE_WEBHOOK_SECRET: Webhook署名 → 開発者 → Webhook → 署名シークレット
#                        ローカルテスト: stripe listen --forward-to localhost:3000/api/stripe/webhook
# ============================================================
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PRICE_MONTHLY="price_..."
STRIPE_PRICE_ANNUAL="price_..."
STRIPE_PRICE_COINS="price_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
