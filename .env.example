# ============================================================
# Neon PostgreSQL
# neon.tech でプロジェクト作成 → Connection Details から取得
# DATABASE_URL: Pooled connection（アプリ用）
# DIRECT_URL:   Direct connection（migrate用）
# ============================================================
DATABASE_URL="postgresql://user:password@ep-xxx.ap-southeast-1.aws.neon.tech/gyosei-lp?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://user:password@ep-xxx.ap-southeast-1.aws.neon.tech/gyosei-lp?sslmode=require"

# ============================================================
# Claude API（https://console.anthropic.com）
# ============================================================
ANTHROPIC_API_KEY="sk-ant-api03-..."

# ============================================================
# NextAuth（管理画面認証）
# AUTH_SECRET: openssl rand -base64 32 で生成
# ADMIN_EMAIL / ADMIN_PASSWORD: 管理画面ログイン用（自分だけ）
# ============================================================
AUTH_SECRET=""
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD=""

# ============================================================
# Resend（メール送信 https://resend.com）
# ============================================================
RESEND_API_KEY="re_..."
RESEND_FROM="noreply@yourdomain.com"
