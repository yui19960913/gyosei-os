generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Client {
  id                String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug              String            @unique @db.VarChar(100)
  firmName          String            @db.VarChar(200)
  ownerName         String            @db.VarChar(100)
  prefecture        String?           @db.VarChar(20)
  email             String            @db.VarChar(255)
  phone             String?           @db.VarChar(20)
  status            String            @default("active") @db.VarChar(20)
  monthlyFee        Int
  contractStartedAt DateTime          @db.Date
  contractEndedAt   DateTime?         @db.Date
  prText            String?
  targetClients     String?
  notes             String?
  createdAt         DateTime          @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime          @updatedAt @db.Timestamptz(6)
  testClient        Boolean           @default(false)
  aiGenerationLogs  AiGenerationLog[]
  invoices          Invoice[]
  landingPages      LandingPage[]
  leads             Lead[]
  monthlyReports    MonthlyReport[]
  sites             Site[]

  @@map("clients")
}

model MagicToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email     String    @db.VarChar(255)
  token     String    @unique @db.VarChar(64)
  expiresAt DateTime  @db.Timestamptz(6)
  usedAt    DateTime? @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @db.Timestamptz(6)

  @@index([token])
  @@map("magic_tokens")
}

model Site {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId  String   @db.Uuid
  name      String   @db.VarChar(200)
  domain    String?  @db.VarChar(255)
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
  pages     Page[]
  client    Client   @relation(fields: [clientId], references: [id])

  @@index([clientId])
  @@map("sites")
}

model AiSite {
  id                   String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug                 String          @unique @db.VarChar(100)
  firmName             String          @db.VarChar(200)
  prefecture           String          @db.VarChar(20)
  services             String[]
  strengths            String
  targetClients        String?
  styles               String[]
  siteContent          Json            @default("{}")
  seoKeywords          Json            @default("[]")
  status               String          @default("draft") @db.VarChar(20)
  autoReply            Boolean         @default(true)
  createdAt            DateTime        @default(now()) @db.Timestamptz(6)
  updatedAt            DateTime        @updatedAt @db.Timestamptz(6)
  promptHash           String?         @db.VarChar(64)
  editorOverlay        Json            @default("[]")
  ownerEmail           String?         @db.VarChar(255)
  ownerName            String?         @db.VarChar(100)
  templateId           String?         @db.VarChar(50)
  plan                 String?         @db.VarChar(20)
  stripeCustomerId     String?         @db.VarChar(100)
  stripeSubscriptionId String?         @db.VarChar(100)
  chatCredits          Int             @default(0)
  lineUserId           String?         @db.VarChar(100)
  seoPages             AiSeoPage[]
  leads                AiSiteLead[]
  reviewRequests       ReviewRequest[]

  @@index([status])
  @@index([promptHash])
  @@map("ai_sites")
}

model AiSiteLead {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  siteId        String    @db.Uuid
  name          String?   @db.VarChar(100)
  email         String?   @db.VarChar(255)
  phone         String?   @db.VarChar(20)
  message       String?
  utmSource     String?   @db.VarChar(100)
  utmMedium     String?   @db.VarChar(100)
  utmCampaign   String?   @db.VarChar(200)
  referrerUrl   String?
  autoReplySent Boolean   @default(false)
  autoReplyAt   DateTime? @db.Timestamptz(6)
  autoReplyText String?
  status        String    @default("new") @db.VarChar(20)
  createdAt     DateTime  @default(now()) @db.Timestamptz(6)
  site          AiSite    @relation(fields: [siteId], references: [id])

  @@index([siteId])
  @@index([createdAt])
  @@map("ai_site_leads")
}

model AiSeoPage {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  siteId    String   @db.Uuid
  slug      String   @db.VarChar(200)
  keyword   String   @db.VarChar(200)
  title     String   @db.VarChar(300)
  content   Json     @default("{}")
  status    String   @default("draft") @db.VarChar(20)
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
  site      AiSite   @relation(fields: [siteId], references: [id])

  @@unique([siteId, slug])
  @@index([siteId])
  @@map("ai_seo_pages")
}

model Reviewer {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String          @db.VarChar(100)
  title          String          @db.VarChar(200)
  company        String          @db.VarChar(200)
  experience     String          @db.VarChar(100)
  speciality     String          @db.VarChar(300)
  bio            String?
  photoUrl       String?         @db.VarChar(500)
  active         Boolean         @default(true)
  createdAt      DateTime        @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime        @updatedAt @db.Timestamptz(6)
  reviewRequests ReviewRequest[]

  @@map("reviewers")
}

model ReviewRequest {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  siteId          String    @db.Uuid
  plan            String    @db.VarChar(20)
  reviewerType    String    @db.VarChar(20)
  reviewerId      String?   @db.Uuid
  status          String    @default("pending") @db.VarChar(20)
  approvedByName  String?   @db.VarChar(100)
  approvedByTitle String?   @db.VarChar(200)
  approvedAt      DateTime? @db.Timestamptz(6)
  note            String?
  amountJpy       Int?
  clientName      String?   @db.VarChar(100)
  clientEmail     String?   @db.VarChar(255)
  createdAt       DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @db.Timestamptz(6)
  reviewer        Reviewer? @relation(fields: [reviewerId], references: [id])
  site            AiSite    @relation(fields: [siteId], references: [id])

  @@index([siteId])
  @@index([status])
  @@index([createdAt])
  @@map("review_requests")
}

model Page {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  siteId    String   @db.Uuid
  slug      String   @db.VarChar(100)
  title     String   @db.VarChar(300)
  status    String   @default("draft") @db.VarChar(20)
  blocks    Json     @default("[]")
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
  site      Site     @relation(fields: [siteId], references: [id])

  @@unique([siteId, slug])
  @@index([siteId])
  @@index([status])
  @@map("pages")
}

model PracticeArea {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug         String        @unique @db.VarChar(100)
  name         String        @db.VarChar(100)
  category     String        @db.VarChar(50)
  description  String?
  sortOrder    Int           @default(0)
  landingPages LandingPage[]
  leads        Lead[]

  @@map("practice_areas")
}

model LandingPage {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId         String            @db.Uuid
  practiceAreaId   String            @db.Uuid
  title            String            @db.VarChar(300)
  status           String            @default("draft") @db.VarChar(20)
  content          Json              @default("{}")
  metaDescription  String?           @db.VarChar(500)
  targetKeywords   String[]
  totalLeads       Int               @default(0)
  publishedAt      DateTime?         @db.Timestamptz(6)
  createdAt        DateTime          @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime          @updatedAt @db.Timestamptz(6)
  aiGenerationLogs AiGenerationLog[]
  client           Client            @relation(fields: [clientId], references: [id])
  practiceArea     PracticeArea      @relation(fields: [practiceAreaId], references: [id])
  leads            Lead[]

  @@unique([clientId, practiceAreaId])
  @@index([clientId])
  @@index([status])
  @@map("landing_pages")
}

model Lead {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId       String       @db.Uuid
  practiceAreaId String       @db.Uuid
  landingPageId  String       @db.Uuid
  name           String?      @db.VarChar(100)
  email          String?      @db.VarChar(255)
  phone          String?      @db.VarChar(20)
  message        String?
  userKeyword    String?      @db.VarChar(300)
  utmSource      String?      @db.VarChar(100)
  utmMedium      String?      @db.VarChar(100)
  utmCampaign    String?      @db.VarChar(200)
  utmTerm        String?      @db.VarChar(300)
  referrerUrl    String?
  status         String       @default("new") @db.VarChar(20)
  notifiedAt     DateTime?    @db.Timestamptz(6)
  createdAt      DateTime     @default(now()) @db.Timestamptz(6)
  testFlag       Boolean      @default(false)
  client         Client       @relation(fields: [clientId], references: [id])
  landingPage    LandingPage  @relation(fields: [landingPageId], references: [id])
  practiceArea   PracticeArea @relation(fields: [practiceAreaId], references: [id])

  @@index([clientId])
  @@index([landingPageId])
  @@index([practiceAreaId])
  @@index([createdAt])
  @@index([status])
  @@map("leads")
}

model Invoice {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId  String    @db.Uuid
  year      Int
  month     Int
  amount    Int
  status    String    @default("draft") @db.VarChar(20)
  issuedAt  DateTime? @db.Timestamptz(6)
  dueDate   DateTime? @db.Date
  paidAt    DateTime? @db.Timestamptz(6)
  pdfUrl    String?   @db.VarChar(500)
  notes     String?
  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @db.Timestamptz(6)
  client    Client    @relation(fields: [clientId], references: [id])

  @@unique([clientId, year, month])
  @@index([clientId])
  @@index([status])
  @@map("invoices")
}

model AiGenerationLog {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId       String       @db.Uuid
  landingPageId  String?      @db.Uuid
  generationType String       @db.VarChar(50)
  promptSnapshot String
  output         String?
  modelName      String       @default("claude-haiku-4-5-20251001") @db.VarChar(100)
  inputTokens    Int?
  outputTokens   Int?
  costUsd        Decimal?     @db.Decimal(10, 6)
  status         String       @default("pending") @db.VarChar(20)
  errorMessage   String?
  durationMs     Int?
  createdAt      DateTime     @default(now()) @db.Timestamptz(6)
  client         Client       @relation(fields: [clientId], references: [id])
  landingPage    LandingPage? @relation(fields: [landingPageId], references: [id])

  @@index([clientId])
  @@index([createdAt])
  @@map("ai_generation_logs")
}

model MonthlyReport {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId            String    @db.Uuid
  year                Int
  month               Int
  status              String    @default("generating") @db.VarChar(20)
  stats               Json      @default("{}")
  aiSummary           String?
  aiSuggestions       String?
  reviewedSummary     String?
  reviewedSuggestions String?
  pdfUrl              String?   @db.VarChar(500)
  sentAt              DateTime? @db.Timestamptz(6)
  createdAt           DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt           DateTime  @updatedAt @db.Timestamptz(6)
  client              Client    @relation(fields: [clientId], references: [id])

  @@unique([clientId, year, month])
  @@map("monthly_reports")
}
